<div class="container">
  <h3 class="section-title"> RECENT WORK</h3>
</div>
{{#each model as |project|}}
  {{#if project.recent}}
    {{#link-to "projects.show" project.id}}
        <div class="pr-th">
          <div class="content">
            <div class="pr-th-img">
              <img src="{{project.thumb}}">
            </div>
            <div class="pr-th-des"><br>
              <h2>{{project.title}}</h2><br>
              TAGS:
              {{#each project.tags as |tag|}}
                  {{tag.tag}},
              {{/each}}
            </div>
          </div>
        </div>
      {{/link-to}}
    {{/if}}
  {{/each}}
