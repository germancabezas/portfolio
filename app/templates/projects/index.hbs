<div class="container">
  <h2> PROJECTS</h2>
</div>
  {{#each model as |project|}}
    <div class="pr-th">
      <div class="content">
        <div class="pr-th-img">
          <img src="{{project.thumb}}">
        </div>
        <div class="pr-th-des">
          {{project.id}}{{project.title}}{{project.description}}
        </div>
      </div>
    </div>
  {{/each}}
{{outlet}}
